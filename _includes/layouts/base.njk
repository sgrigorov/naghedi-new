{# Shared site chrome: header + footer come from partials, every page extends this. #}
<!doctype html>
<html lang="{{ site.lang }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% if title %}{{ title }} | {% endif %}{{ site.title }}</title>
    <meta name="description" content="{{ description or site.description }}">
    <link rel="icon" type="image/x-icon" href="/assets/images/favicon.ico">
    <link rel="stylesheet" href="/assets/css/site.css">
    <link rel="stylesheet" href="/assets/css/static.css">
    <style>
      /* Squarespace hides these classes until its runtime JS renders them.
         We don't ship that JS, so reveal them unconditionally. */
      .background-image-fx,
      img[data-src]:not([src]):not([srcset]) { visibility: visible !important; }
    </style>
    {% if page.url != "/" %}
    <style>
      /* The site uses tweak-transparent-header: nav text is white so it reads
         over the home page's dark hero. Other pages don't have that hero, so
         white-on-white nav disappears. Force dark nav + dark footer text on
         every page except home. */
      body {
        --navigationLinkColor: hsla(var(--black-hsl), 1) !important;
        --gradientHeaderNavigationColor: hsla(var(--black-hsl), 1) !important;
        --solidHeaderNavigationColor: hsla(var(--black-hsl), 1) !important;
        --siteTitleColor: hsla(var(--black-hsl), 1) !important;
      }
      .header-nav-wrapper a,
      .header-nav-wrapper a *,
      .header-title a,
      .header-actions a { color: #1a1a1a !important; }
      #footer-sections,
      #footer-sections * { color: #1a1a1a !important; }
      #footer-sections a,
      #footer-sections a * { color: #1a3d8f !important; }
    </style>
    {% endif %}
    {% block head %}{% endblock %}
  </head>
  <body class="{{ site.bodyClass }}" tabindex="-1">
    <div id="siteWrapper" class="clearfix site-wrapper">
      {% include "partials/header.njk" %}
      {{ content | safe }}
      {% include "partials/footer.njk" %}
    </div>
    <script>
      // Squarespace CSS hides images until parent gets data-loaded.
      // Their loader JS used to set it; we don't ship the loader, so do it ourselves.
      (function () {
        function reveal() {
          document.querySelectorAll('img').forEach(function (img) {
            img.setAttribute('data-loaded', '');
            var p = img.parentElement;
            while (p && p !== document.body) {
              p.setAttribute('data-loaded', '');
              p = p.parentElement;
            }
          });
        }
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', reveal);
        } else {
          reveal();
        }
      })();
    </script>
  </body>
</html>

{# Shared site chrome: header + footer come from partials, every page extends this. #}
<!doctype html>
<html lang="{{ site.lang }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% if title %}{{ title }} | {% endif %}{{ site.title }}</title>
    <meta name="description" content="{{ description or site.description }}">
    <link rel="icon" type="image/x-icon" href="/assets/images/favicon.ico">
    <link rel="stylesheet" href="/assets/css/site.css">
    <link rel="stylesheet" href="/assets/css/static.css">
    <script src="https://use.typekit.net/ik/dx2W-9ohBe9X7GGJ0051O-H76Wpb1j_sonOCDFGzlabfeCJgfFHN4UJLFRbh52jhWDju5QFyjcwuwhJD5ewoFhFqjAjujQwD5gGMJ6lzS1gGZWmDOWgkdkJZdcmuZPuGjABDOAikdas8ShClZe8DSeUypPGHf50rMsMMeMb6MKGHf5crMsMMeMS6MKGHf57rMsMMeMt6MKGHfw-XMyMgeMb6MKGHfwKXMyMgeM96MKGHfwkXMyMgeMS6MKGHfwpXMyMgeMt6MKGHfwcXMyMgeMv6MKGHfwhXMyMgegI6MTMg_5AyCbj.js"></script>
    <script>try { Typekit.load({ async: true }); } catch (e) {}</script>
    <style>
      /* Squarespace hides these classes until its runtime JS renders them.
         We don't ship that JS, so reveal them unconditionally. */
      .background-image-fx,
      img[data-src]:not([src]):not([srcset]) { visibility: visible !important; }
      /* Make the Services dropdown a readable white panel on every page.
         The underlying page wrapper has data-section-theme="black", which
         makes the surrounding area show through as black behind the
         transparent dropdown. Paint our own panel and force dark text. */
      .header-nav-folder-content {
        background-color: #ffffff !important;
        border-radius: 4px !important;
      }
      .header-nav-folder-content,
      .header-nav-folder-content * { color: #1a1a1a !important; }
    </style>
    {% if page.url != "/" %}
    <style>
      /* The site uses tweak-transparent-header: nav text is white so it reads
         over the home page's dark hero. Other pages don't have that hero, so
         white-on-white nav disappears. Force dark nav + dark footer text on
         every page except home. */
      body {
        --navigationLinkColor: hsla(var(--black-hsl), 1) !important;
        --gradientHeaderNavigationColor: hsla(var(--black-hsl), 1) !important;
        --solidHeaderNavigationColor: hsla(var(--black-hsl), 1) !important;
        --siteTitleColor: hsla(var(--black-hsl), 1) !important;
      }
      .header-nav-wrapper a,
      .header-nav-wrapper a *,
      .header-title a,
      .header-actions a { color: #1a1a1a !important; }
      #footer-sections,
      #footer-sections * { color: #1a1a1a !important; }
      #footer-sections a,
      #footer-sections a * { color: #1a3d8f !important; }
      /* Push page content below the transparent header so it doesn't
         start flush under the nav. Home page has its own hero spacing. */
      #page { padding-top: 80px; }
    </style>
    {% endif %}
    {% block head %}{% endblock %}
  </head>
  <body class="{{ site.bodyClass }}" tabindex="-1">
    <svg aria-hidden="true" focusable="false" style="position:absolute;width:0;height:0;overflow:hidden" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <filter id="liquid-effect">
          <feTurbulence type="fractalNoise" baseFrequency="0.012 0.018" numOctaves="2" seed="3" result="noise">
            <animate attributeName="baseFrequency" dur="14s" values="0.010 0.016;0.018 0.012;0.010 0.016" repeatCount="indefinite"/>
          </feTurbulence>
          <feDisplacementMap in="SourceGraphic" in2="noise" scale="22" xChannelSelector="R" yChannelSelector="G"/>
        </filter>
      </defs>
    </svg>
    <style>
      /* Squarespace marks the circular image container with
         data-shape-mask="circle" and normally clips it with a SVG <clipPath>
         generated by its runtime JS (clip-path: url(#yui_…)). We don't ship
         that runtime, so override with a plain CSS circle clip and force the
         container to a 1:1 box so the circle is a full circle. */
      .fluid-image-container[data-shape-mask="circle"] {
        aspect-ratio: 1 / 1 !important;
        height: auto !important;
        width: 60% !important;
        margin-left: auto !important;
        margin-right: auto !important;
        clip-path: circle(50% at 50% 50%) !important;
        -webkit-clip-path: circle(50% at 50% 50%) !important;
      }
      /* Animated "liquid" image effect (was Squarespace WebGL).
         Apply the circular clip-path on the same element as the filter
         so the clip is applied after the displacement and the visible
         edge stays perfectly steady. */
      .sqs-block-image:has(.imageEffectContainer[data-effect*="liquid"]) img {
        filter: url(#liquid-effect);
        clip-path: circle(49% at 50% 50%);
        -webkit-clip-path: circle(49% at 50% 50%);
      }
      .sqs-block-image .imageEffectContainer { display: none; }
    </style>
    <div id="siteWrapper" class="clearfix site-wrapper">
      {% include "partials/header.njk" %}
      {{ content | safe }}
      {% include "partials/footer.njk" %}
    </div>
    <script>
      // Squarespace bakes header-nav-item--active onto the home link in every
      // page's static HTML. Move that class to the link that actually matches
      // window.location.pathname so the underline indicator follows the page.
      (function () {
        function setActiveNav() {
          var path = window.location.pathname.replace(/\/+$/, '') || '/';
          document.querySelectorAll('.header-nav-item').forEach(function (item) {
            var links = item.querySelectorAll('a[href]');
            var topLink = links[0];
            var match = false;
            links.forEach(function (a) {
              var href = (a.getAttribute('href') || '').replace(/\/+$/, '') || '/';
              if (!href || href.charAt(0) !== '/') return;
              if (href === path || (href !== '/' && path.indexOf(href + '/') === 0)) {
                match = true;
              }
              a.removeAttribute('aria-current');
            });
            if (match) {
              item.classList.add('header-nav-item--active');
              if (topLink) topLink.setAttribute('aria-current', 'page');
            } else {
              item.classList.remove('header-nav-item--active');
            }
          });
          // Mark the matching dropdown item inside the Services folder.
          document.querySelectorAll('.header-nav-folder-item').forEach(function (item) {
            var a = item.querySelector('a[href]');
            if (!a) return;
            var href = (a.getAttribute('href') || '').replace(/\/+$/, '') || '/';
            if (href && href.charAt(0) === '/' &&
                (href === path || (href !== '/' && path.indexOf(href + '/') === 0))) {
              item.classList.add('header-nav-folder-item--active');
            } else {
              item.classList.remove('header-nav-folder-item--active');
            }
          });
        }
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', setActiveNav);
        } else {
          setActiveNav();
        }
      })();
    </script>
    <script>
      // Squarespace CSS hides images until parent gets data-loaded.
      // Their loader JS used to set it; we don't ship the loader, so do it ourselves.
      (function () {
        function reveal() {
          document.querySelectorAll('img').forEach(function (img) {
            img.setAttribute('data-loaded', '');
            var p = img.parentElement;
            while (p && p !== document.body) {
              p.setAttribute('data-loaded', '');
              p = p.parentElement;
            }
          });
        }
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', reveal);
        } else {
          reveal();
        }
      })();
    </script>
    <script>
      // Squarespace accordion blocks (.sqs-block-accordion) rely on their JS
      // to toggle .accordion-item__dropdown--open and data-is-open. We don't
      // ship that JS, so the items would stay collapsed. Wire up click + key.
      (function () {
        function setOpen(item, open) {
          var dropdown = item.querySelector('.accordion-item__dropdown');
          var icon = item.querySelector('.accordion-icon-container');
          var btn = item.querySelector('.accordion-item__click-target');
          item.setAttribute('data-is-open', String(open));
          if (icon) icon.setAttribute('data-is-open', String(open));
          if (btn) btn.setAttribute('aria-expanded', String(open));
          if (dropdown) dropdown.classList.toggle('accordion-item__dropdown--open', open);
        }
        document.addEventListener('click', function (e) {
          var btn = e.target.closest && e.target.closest('.accordion-item__click-target');
          if (!btn) return;
          var item = btn.closest('.accordion-item');
          if (!item) return;
          var open = item.getAttribute('data-is-open') === 'true';
          var next = !open;
          // Close siblings within the same accordion block so only one is open at a time.
          var block = item.closest('.sqs-block-accordion') || item.parentElement;
          if (block && next) {
            block.querySelectorAll('.accordion-item').forEach(function (other) {
              if (other !== item) setOpen(other, false);
            });
          }
          setOpen(item, next);
        });
      })();
    </script>
  </body>
</html>
